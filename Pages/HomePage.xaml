<?xml version="1.0" encoding="utf-8" ?>
<!-- Home page where users enter food and estimate nutrition -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HealthLog.Pages.HomePage"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border Stroke="Black"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 0"
        Padding="10">
                <Label Text="{Binding DateText}"
           FontSize="16" />
            </Border>
            
            <Border Stroke="Black"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 0"
        Padding="10">
                <Entry Text="{Binding FoodInput}"
           Placeholder="Please enter the text." />
            </Border>

            <Button Text="Estimate"
                    Command="{Binding EstimateCommand}" />
            
            <Border Stroke="Black"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 0"
        Padding="10">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Estimated Nutrition:"
               FontSize="16" />
                    <Label Text="{Binding CaloriesText}" />
                    <Label Text="{Binding ProteinText}" />
                    <Label Text="{Binding CarbsText}" />
                    <Label Text="{Binding FatText}" />
                    <Label Text="{Binding WaterText}" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="Black"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 0"
        Padding="10">
                <Label Text="{Binding SuggestionText}"
           LineBreakMode="WordWrap" />
            </Border>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                <Button Text="Home"
            Grid.Column="0" >
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                     Binding="{Binding IsHomePage}"
                     Value="True">
                        <Setter Property="TextColor" Value="Red" />
                    </DataTrigger>
                </Button.Triggers>
                </Button>

                <Button Text="Previous Records"
            Grid.Column="1"
            Command="{Binding PreviousRecordsCommand}" />

                <Button Text="Goals &amp; Setting"
            Grid.Column="2" />

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>