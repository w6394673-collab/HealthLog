<?xml version="1.0" encoding="utf-8" ?>
<!-- Login page UI layout -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HealthLog.Pages.LoginPage"
             Title="Login">
    <!-- Vertical layout used to arrange elements from top to bottom -->
    <VerticalStackLayout Padding="30" Spacing="20">
        <!-- Page title -->
        <Label
            Text="Log in"
            FontSize="28"
            HorizontalOptions="Center"
            FontAttributes="Bold" />
        <!-- Instruction for username input -->
        <Label Text="Please enter your username." />
        <!-- Username input box -->
        <Entry
            x:Name="usernameEntry"
            Placeholder="Username" />
        <!-- Username input box -->
        <Label Text="Please enter your password." />
        <!-- Instruction for password input -->
        <Entry
            x:Name="passwordEntry"
            Placeholder="Password"
            IsPassword="True" />
        <!-- Password input box (hidden text) -->
        <Button
            Text="Enter"
            WidthRequest="200"
            HorizontalOptions="Center"
            Clicked="OnLoginClicked" />

    </VerticalStackLayout>

</ContentPage>