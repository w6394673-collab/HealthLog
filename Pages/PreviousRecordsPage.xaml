<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HealthLog.Pages.PreviousRecordsPage"
             Title="Previous Records">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Previous Records"
                   FontSize="24"
                   HorizontalOptions="Center" />

            <CollectionView ItemsSource="{Binding Records}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="Black"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 0"
        Padding="10"
        Margin="0,0,0,10">

                            <VerticalStackLayout Spacing="10">

                                <Label Text="{Binding SummaryText}" />

                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="View"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewCommand}"
                    CommandParameter="{Binding .}"
                    HorizontalOptions="FillAndExpand" />

                                    <Button Text="Delete"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                    CommandParameter="{Binding .}"
                    HorizontalOptions="FillAndExpand" />
                                </HorizontalStackLayout>

                            </VerticalStackLayout>

                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                <Button Text="Home"
                        Grid.Column="0"
                        Command="{Binding HomeCommand}" />
                <Button Text="Previous Records"
        Grid.Column="1">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                     Binding="{Binding IsPreviousPage}"
                     Value="True">
                            <Setter Property="TextColor" Value="Red" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Goals &amp; Setting"
                        Grid.Column="2" />

            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>