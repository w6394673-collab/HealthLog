<?xml version="1.0" encoding="utf-8" ?>
<!-- Page used to display all saved food records -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HealthLog.Pages.PreviousRecordsPage"
             Title="Previous Records">
    <!-- Main layout for the page -->
    <VerticalStackLayout Padding="20" Spacing="20">
        <!-- CollectionView shows a list of saved records -->
        <CollectionView x:Name="recordsCollectionView"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <!-- Each record displayed inside a frame -->
                    <Frame BorderColor="Black"
                           CornerRadius="0"
                           HasShadow="False"
                           Padding="10"
                           Margin="0,0,0,10">

                        <VerticalStackLayout Spacing="10">
                            <!-- Display summary text of the record -->
                            <Label Text="{Binding SummaryText}" />
                            <!-- Buttons to view details or delete the record -->
                            <HorizontalStackLayout Spacing="10">
                                <Button Text="View"
                                        Clicked="OnViewClicked"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Delete"
                                        Clicked="OnDeleteClicked"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
        <!-- Bottom navigation buttons -->
        <Grid ColumnDefinitions="*,*,*"
              ColumnSpacing="10"
              Margin="0,20,0,0">

            <Button Text="Home"
                    Clicked="OnHomeClicked"
                    Grid.Column="0" />

            <Button Text="Previous Records"
                    TextColor="Red"
                    Grid.Column="1" />

            <Button Text="Goals &amp; Setting"
                    Grid.Column="2" />
        </Grid>

    </VerticalStackLayout>
</ContentPage>